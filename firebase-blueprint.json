{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user subscription and usage data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "email": { "type": "string", "description": "The email address of the user" },
        "displayName": { "type": "string", "description": "The display name of the user" },
        "isPremium": { "type": "boolean", "description": "Whether the user has a premium subscription" },
        "searchCount": { "type": "number", "description": "Number of searches performed" },
        "trendsClickCount": { "type": "number", "description": "Number of times market trends were viewed" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" }
      },
      "required": ["uid", "email", "isPremium", "searchCount", "trendsClickCount"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Stores user suggestions and issue reports",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user who submitted the feedback" },
        "email": { "type": "string", "description": "The email address of the user" },
        "type": { "type": "string", "enum": ["suggestion", "issue"], "description": "The type of feedback" },
        "message": { "type": "string", "description": "The feedback message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the feedback was submitted" }
      },
      "required": ["uid", "email", "type", "message", "createdAt"]
    },
    "Drawing": {
      "title": "Stock Chart Drawings",
      "description": "Stores user trendlines and annotations for a specific stock and timeframe",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "symbol": { "type": "string", "description": "The stock symbol" },
        "timeframe": { "type": "string", "description": "The chart timeframe (1D, 1M, 1Y)" },
        "trendlines": { "type": "array", "description": "List of trendlines" },
        "annotations": { "type": "array", "description": "List of annotations" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the drawings were last updated" }
      },
      "required": ["uid", "symbol", "timeframe", "trendlines", "annotations", "updatedAt"]
    },
    "Alert": {
      "title": "Price Alert",
      "description": "Stores user-defined stock price alerts",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "symbol": { "type": "string", "description": "The stock symbol" },
        "targetValue": { "type": "number", "description": "The target price or percentage" },
        "type": { "type": "string", "enum": ["price_above", "price_below", "gain_above", "loss_above", "ma_cross_above", "ma_cross_below"], "description": "The type of alert" },
        "active": { "type": "boolean", "description": "Whether the alert is currently active" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the alert was created" },
        "triggeredAt": { "type": "string", "format": "date-time", "description": "When the alert was triggered" },
        "params": { "type": "object", "description": "Additional parameters like MA period" }
      },
      "required": ["uid", "symbol", "targetValue", "type", "active", "createdAt"]
    },
    "Notification": {
      "title": "In-App Notification",
      "description": "Stores notifications for the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "title": { "type": "string", "description": "The notification title" },
        "message": { "type": "string", "description": "The notification message" },
        "type": { "type": "string", "enum": ["alert", "system", "news"], "description": "The type of notification" },
        "read": { "type": "boolean", "description": "Whether the notification has been read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the notification was created" },
        "data": { "type": "object", "description": "Additional metadata for the notification" }
      },
      "required": ["uid", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback submissions"
    },
    "/drawings/{drawingId}": {
      "schema": "Drawing",
      "description": "User chart drawings"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "User price alerts"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User in-app notifications"
    }
  }
}
