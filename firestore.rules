rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - isPremium: boolean (required)
    //   - searchCount: number (required)
    //   - trendsClickCount: number (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: drawings
    // Document ID: {drawingId}
    // Fields:
    //   - uid: string (required)
    //   - symbol: string (required)
    //   - timeframe: string (required)
    //   - trendlines: list (required)
    //   - annotations: list (required)
    //   - updatedAt: string (required)
    //
    // Collection: alerts
    // Document ID: {alertId}
    // Fields:
    //   - uid: string (required)
    //   - symbol: string (required)
    //   - targetValue: number (required)
    //   - type: string (required)
    //   - active: boolean (required)
    //   - createdAt: string (required)
    //   - triggeredAt: string (optional)
    //   - params: map (optional)
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - uid: string (required)
    //   - title: string (required)
    //   - message: string (required)
    //   - type: string (required)
    //   - read: boolean (required)
    //   - createdAt: string (required)
    //   - data: map (optional)
    // ===============================================================

    // Helper Functions
    function isAdmin() {
      return false;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /feedback/{feedbackId} {
      allow read: if false;
      allow create: if true;
    }

    match /drawings/{drawingId} {
      allow read, write: if true;
    }

    match /alerts/{alertId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
